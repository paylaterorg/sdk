# Copy this file to `.env` (in the same directory) and drop in your own
# sandbox key issued from https://paylater.dev. The showcase falls back to
# `pk_test_examplekey1234567890` when this is unset, which renders the widget with its
# "Provide a valid pk_test_* / pk_live_* API key" warning.
VITE_PAYLATER_API_KEY=pk_test_examplekey1234567890
